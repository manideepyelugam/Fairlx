# ==========================================
# Fairlx Environment Configuration Template
# ==========================================
# Copy this file to .env.local and fill in the values.
# Variables marked with [PRIVATE] should never be exposed to the client.

# ─── 1. PROJECT CONFIGURATION ──────────────
# Base URL of the application
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Node environment (development, production, test)
NODE_ENV=development

# ─── 2. APPWRITE CORE ──────────────────────
# Endpoint and Project ID from Appwrite Console
NEXT_PUBLIC_APPWRITE_ENDPOINT=
NEXT_PUBLIC_APPWRITE_PROJECT=
# [PRIVATE] Appwrite API Key with full database/storage permissions
NEXT_APPWRITE_KEY=

# ─── 3. SECURITY & SECRETS ─────────────────
# [PRIVATE] Secret token for authenticating cron job requests
CRON_SECRET=
# [PRIVATE] secret for wallet signature verification
WALLET_SIG_SECRET=
# [PRIVATE] Encryption secret for 2FA recovery codes (32-char hex string)
TWO_FACTOR_ENCRYPTION_SECRET=
# [PRIVATE] Secret for internal Socket.IO push endpoint
SOCKET_PUSH_SECRET=
# [PRIVATE] Encryption key for BYOB tenant env blobs (32-byte hex string)
BYOB_ENCRYPTION_SECRET=

# ─── 4. BILLING & PRICING ──────────────────
# Default billing grace period in days
BILLING_GRACE_PERIOD_DAYS=14
# Primary currency (e.g., USD, INR)
BILLING_CURRENCY=USD
# Usage rates (in currency units per unit)
USAGE_RATE_TRAFFIC_GB=0.10
USAGE_RATE_STORAGE_GB_MONTH=0.05
USAGE_RATE_COMPUTE_UNIT=0.001

# ─── 5. PAYMENT GATEWAY (CASHFREE) ──────────
# [PRIVATE] Cashfree API Credentials
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
# [PRIVATE] Cashfree Webhook Secret for payment confirmation
CASHFREE_WEBHOOK_SECRET=
# [PRIVATE] Cashfree Environment (SANDBOX or PRODUCTION)
CASHFREE_ENV=SANDBOX
# [PRIVATE] API key for live USD <-> INR conversion
EXCHANGE_RATE_API_KEY=

# ─── 6. WALLETS ───────────────────────────
# Maximum daily top-up amount for individual wallets (in paise/cents)
WALLET_DAILY_TOPUP_LIMIT=50000000

# ─── 7. EXTERNAL APIS ─────────────────────
# [PRIVATE] GitHub Personal Access Token (for higher rate limits)
GH_PERSONAL_TOKEN=
# [PRIVATE] Google Gemini API key for AI-generated summaries
GEMINI_API_KEY=

# ─── 8. APPWRITE MESSAGING ────────────────
# [PRIVATE] Appwrite SMTP provider ID
NEXT_PUBLIC_APPWRITE_SMTP_PROVIDER_ID=
# [PRIVATE] Topic ID for automated email notifications
NEXT_PUBLIC_APPWRITE_EMAIL_TOPIC_ID=

# ─── 9. CLOUDFLARE R2 STORAGE (OPTIONAL) ──
# When set, the app uses R2 instead of Appwrite Storage for production.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fairlx-storage
# Custom domain pointing to your R2 bucket
R2_PUBLIC_URL=

# ─── 10. LANDING PAGE (SUPABASE) ──────────
# Used for data fetching on the external landing page
LANDING_SUPABASE_URL=
# [PRIVATE] Service role key (bypasses RLS - server-side only)
LANDING_SUPABASE_SERVICE_ROLE_KEY=

# ─── 11. REDIS CACHING ───────────────────
# [PRIVATE] Redis connection URL (redis://user:pass@host:port)
REDIS_URL=
# [PRIVATE] Redis password
REDIS_PASSWORD=

# ─── 12. DATABASE SCHEMA (AUTO-GENERATED) ──
# Database ID
NEXT_PUBLIC_APPWRITE_DATABASE_ID=fairlx

# -- Core & Workspace --
NEXT_PUBLIC_APPWRITE_WORKSPACES_ID=workspaces
NEXT_PUBLIC_APPWRITE_MEMBERS_ID=members
NEXT_PUBLIC_APPWRITE_PROJECTS_ID=projects
NEXT_PUBLIC_APPWRITE_PROJECT_MEMBERS_ID=project_members
NEXT_PUBLIC_APPWRITE_PROJECT_ROLES_ID=project_roles

# -- Work Management --
NEXT_PUBLIC_APPWRITE_WORK_ITEMS_ID=workItems
NEXT_PUBLIC_APPWRITE_TASKS_ID=workItems
NEXT_PUBLIC_APPWRITE_SPRINTS_ID=sprints
NEXT_PUBLIC_APPWRITE_PERSONAL_BACKLOG_ID=personalBacklog
